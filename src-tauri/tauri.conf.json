{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cobble",
  "version": "0.1.1",
  "identifier": "com.cobble.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Cobble",
        "width": 1400,
        "height": 900,
        "minWidth": 320,
        "minHeight": 160,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "fullscreen": false,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 25
        },
        "hiddenTitle": true,
        "visible": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {
        "Resources/Assets.car": "resources/Assets.car",
        "Resources/cobble-icon.icns": "resources/cobble-icon.icns"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5NEUyN0FERjFGMUJBMUEKUldRYXV2SHhyU2RPYVczWUhsdDMxdHVLdkVPaEtNV2Q4OW5kRnR4ZEdaV0F1RlFTQlhla2IvdmEK",
      "endpoints": [
        "https://github.com/lupfister/git-visualizer/releases/latest/download/latest.json"
      ]
    }
  }
}
