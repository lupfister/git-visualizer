{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Visualizer",
  "version": "0.1.0",
  "identifier": "com.gitvisualizer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Git Visualizer",
        "width": 520,
        "height": 760,
        "minWidth": 460,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
